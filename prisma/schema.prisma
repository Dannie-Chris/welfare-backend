generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int              @id @default(autoincrement())
  name          String
  email         String           @unique
  phone         String?
  password      String
  role          String           @default("member")
  createdAt     DateTime         @default(now())
  activityLogs  ActivityLog[]
  contributions Contribution[]
  requests      WelfareRequest[]
}

model Contribution {
  id                 Int      @id @default(autoincrement())
  userId             Int
  month              String
  year               Int
  amount             Int
  paymentStatus      String   @default("Pending")
  paymentDate        String?
  paymentMethod      String?
  outstandingBalance Int      @default(0)
  totalContributions Int      @default(0)
  reference          String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id])
}

model WelfareRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  requestType String
  amount      Float
  reason      String
  priority    String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   String?
  details    String
  userId     Int
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
